{
  "name": "spec-code",
  "displayName": "Spec-Code: SpecCode-Compatible Spec-Driven AI Development",
  "description": "Bring SpecCode's agentic IDE capabilities to any VS Code installation. Spec-driven development with any AI model.",
  "version": "1.0.0",
  "publisher": "spec-code",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "specCode",
    "spec-driven",
    "claude",
    "openai",
    "mcp",
    "code-generation",
    "assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specCode.newSession",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "specCode.viewSessions",
        "title": "View Sessions",
        "icon": "$(list-unordered)"
      },
      {
        "command": "specCode.endSession",
        "title": "End Session",
        "icon": "$(stop)"
      },
      {
        "command": "specCode.viewMemory",
        "title": "View Memory",
        "icon": "$(database)"
      },
      {
        "command": "specCode.clearMemory",
        "title": "Clear Memory",
        "icon": "$(clear-all)"
      },
      {
        "command": "specCode.explainCode",
        "title": "Explain Code",
        "icon": "$(question)"
      },
      {
        "command": "specCode.fixCode",
        "title": "Fix Code",
        "icon": "$(wrench)"
      },
      {
        "command": "specCode.askAboutCode",
        "title": "Ask About Code",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "specCode.generateCommitMessage",
        "title": "Generate Commit Message",
        "icon": "$(git-commit)"
      },
      {
        "command": "specCode.reviewChanges",
        "title": "Review Changes",
        "icon": "$(diff)"
      },
      {
        "command": "specCode.openChat",
        "title": "Open Spec-Code Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "specCode.newSpec",
        "title": "New Spec",
        "icon": "$(new-file)"
      },
      {
        "command": "specCode.editSpec",
        "title": "Edit Spec",
        "icon": "$(edit)"
      },
      {
        "command": "specCode.deleteSpec",
        "title": "Delete Spec",
        "icon": "$(trash)"
      },
      {
        "command": "specCode.generateRequirements",
        "title": "Generate Requirements",
        "icon": "$(sparkle)"
      },
      {
        "command": "specCode.generateDesign",
        "title": "Generate Design",
        "icon": "$(lightbulb)"
      },
      {
        "command": "specCode.generateTasks",
        "title": "Generate Implementation Plan",
        "icon": "$(checklist)"
      },
      {
        "command": "specCode.executeTasks",
        "title": "Execute Tasks",
        "icon": "$(play)"
      },
      {
        "command": "specCode.newHook",
        "title": "New Agent Hook",
        "icon": "$(add)"
      },
      {
        "command": "specCode.editHook",
        "title": "Edit Hook",
        "icon": "$(edit)"
      },
      {
        "command": "specCode.toggleHook",
        "title": "Toggle Hook",
        "icon": "$(check)"
      },
      {
        "command": "specCode.deleteHook",
        "title": "Delete Hook",
        "icon": "$(trash)"
      },
      {
        "command": "specCode.newSteering",
        "title": "New Steering Document",
        "icon": "$(add)"
      },
      {
        "command": "specCode.editSteering",
        "title": "Edit Steering",
        "icon": "$(edit)"
      },
      {
        "command": "specCode.addMCPServer",
        "title": "Add MCP Server",
        "icon": "$(add)"
      },
      {
        "command": "specCode.removeMCPServer",
        "title": "Remove MCP Server",
        "icon": "$(trash)"
      },
      {
        "command": "specCode.refreshMCP",
        "title": "Refresh MCP Servers",
        "icon": "$(refresh)"
      },
      {
        "command": "specCode.openSettings",
        "title": "Open Spec-Code Settings",
        "icon": "$(gear)"
      },
      {
        "command": "specCode.openProviderSetup",
        "title": "Open Provider Setup",
        "icon": "$(settings-gear)"
      },
      {
        "command": "specCode.addModel",
        "title": "Add AI Model",
        "icon": "$(add)"
      },
      {
        "command": "specCode.testModel",
        "title": "Test Model Connection",
        "icon": "$(debug-start)"
      },
      {
        "command": "specCode.approvePhase",
        "title": "Approve Phase",
        "icon": "$(check)"
      },
      {
        "command": "specCode.regeneratePhase",
        "title": "Regenerate Phase",
        "icon": "$(refresh)"
      },
      {
        "command": "specCode.startTask",
        "title": "Start Task",
        "icon": "$(play)"
      },
      {
        "command": "specCode.toggleTaskOptional",
        "title": "Toggle Optional",
        "icon": "$(circle-outline)"
      },
      {
        "command": "specCode.approveCommand",
        "title": "Approve Command",
        "icon": "$(check)"
      },
      {
        "command": "specCode.cancelCommand",
        "title": "Cancel Command",
        "icon": "$(x)"
      },
      {
        "command": "specCode.newSpecFromTemplate",
        "title": "New Spec from Template",
        "icon": "$(new-file)"
      },
      {
        "command": "specCode.generateTests",
        "title": "Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "specCode.generateDocs",
        "title": "Generate Documentation",
        "icon": "$(book)"
      },
      {
        "command": "specCode.reviewCurrentFile",
        "title": "Review Current File",
        "icon": "$(checklist)"
      },
      {
        "command": "specCode.askAboutSelection",
        "title": "Ask About Selection",
        "icon": "$(question)"
      },
      {
        "command": "specCode.clearSpecMemory",
        "title": "Clear Spec Memory",
        "icon": "$(clear-all)"
      },
      {
        "command": "specCode.resumeSession",
        "title": "Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "specCode.addProvider",
        "title": "Add Provider",
        "icon": "$(add)"
      },
      {
        "command": "specCode.editProvider",
        "title": "Edit Provider",
        "icon": "$(edit)"
      },
      {
        "command": "specCode.removeProvider",
        "title": "Remove Provider",
        "icon": "$(trash)"
      },
      {
        "command": "specCode.switchProvider",
        "title": "Switch Provider",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "specCode.testProvider",
        "title": "Test Provider Connection",
        "icon": "$(debug-start)"
      },
      {
        "command": "specCode.discoverProviders",
        "title": "Discover Local Providers",
        "icon": "$(search)"
      },
      {
        "command": "specCode.importProviderConfig",
        "title": "Import Provider Configuration",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specCode.exportProviderConfig",
        "title": "Export Provider Configuration",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "specCode.clearCredentials",
        "title": "Clear All API Keys",
        "icon": "$(clear-all)"
      },
      {
        "command": "specCode.activateProvider",
        "title": "Activate Provider",
        "icon": "$(check)"
      },
      {
        "command": "specCode.setPhaseProvider",
        "title": "Set Phase Provider",
        "icon": "$(gear)"
      },
      {
        "command": "specCode.refreshProviderStatus",
        "title": "Refresh Provider Status",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specCode",
          "title": "Spec-Code",
          "icon": "$(ghost)"
        }
      ]
    },
    "views": {
      "specCode": [
        {
          "id": "specCode.chat",
          "name": "Chat",
          "type": "webview",
          "when": "workspaceHasSpecCodeFolder || true",
          "icon": "$(comment-discussion)"
        },
        {
          "id": "specCode.providerSetup",
          "name": "Provider Setup",
          "type": "webview",
          "when": "workspaceHasSpecCodeFolder || true",
          "icon": "$(settings-gear)"
        },
        {
          "id": "specCode.providerSwitcher",
          "name": "Provider Switcher",
          "icon": "$(arrow-swap)",
          "when": "workspaceHasSpecCodeFolder || true"
        },
        {
          "id": "specCode.specs",
          "name": "Specs",
          "icon": "$(file-text)",
          "when": "workspaceHasSpecCodeFolder || true"
        },
        {
          "id": "specCode.hooks",
          "name": "Agent Hooks",
          "icon": "$(debug-disconnect)",
          "when": "workspaceHasSpecCodeFolder || true"
        },
        {
          "id": "specCode.steering",
          "name": "Agent Steering",
          "icon": "$(compass)",
          "when": "workspaceHasSpecCodeFolder || true"
        },
        {
          "id": "specCode.sessions",
          "name": "Sessions",
          "icon": "$(history)",
          "when": "workspaceHasSpecCodeFolder || true"
        },
        {
          "id": "specCode.mcp",
          "name": "MCP Servers",
          "icon": "$(server)",
          "when": "workspaceHasSpecCodeFolder || true"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "specCode.specs",
        "contents": "No specs yet. [New Spec](command:specCode.newSpec)"
      },
      {
        "view": "specCode.hooks",
        "contents": "No agent hooks configured. [New Hook](command:specCode.newHook)"
      },
      {
        "view": "specCode.steering",
        "contents": "No steering documents. [New Steering](command:specCode.newSteering)"
      },
      {
        "view": "specCode.sessions",
        "contents": "No active sessions. [New Session](command:specCode.newSession)"
      },
      {
        "view": "specCode.mcp",
        "contents": "No MCP servers. [Add Server](command:specCode.addMCPServer)"
      },
      {
        "view": "specCode.providerSwitcher",
        "contents": "No providers configured. [Add Provider](command:specCode.addProvider)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specCode.newSpec",
          "when": "view == specCode.specs",
          "group": "navigation"
        },
        {
          "command": "specCode.newHook",
          "when": "view == specCode.hooks",
          "group": "navigation"
        },
        {
          "command": "specCode.newSteering",
          "when": "view == specCode.steering",
          "group": "navigation"
        },
        {
          "command": "specCode.newSession",
          "when": "view == specCode.sessions",
          "group": "navigation"
        },
        {
          "command": "specCode.addMCPServer",
          "when": "view == specCode.mcp",
          "group": "navigation"
        },
        {
          "command": "specCode.refreshMCP",
          "when": "view == specCode.mcp",
          "group": "navigation"
        },
        {
          "command": "specCode.refreshProviderStatus",
          "when": "view == specCode.providerSwitcher",
          "group": "navigation"
        },
        {
          "command": "specCode.addProvider",
          "when": "view == specCode.providerSwitcher",
          "group": "navigation",
          "icon": "$(add)"
        },
        {
          "command": "specCode.discoverProviders",
          "when": "view == specCode.providerSwitcher",
          "group": "navigation",
          "icon": "$(search)"
        }
      ],
      "view/item/context": [
        {
          "command": "specCode.editSpec",
          "when": "view == specCode.specs && viewItem == spec",
          "group": "inline"
        },
        {
          "command": "specCode.deleteSpec",
          "when": "view == specCode.specs && viewItem == spec",
          "group": "inline"
        },
        {
          "command": "specCode.generateRequirements",
          "when": "view == specCode.specs && viewItem == spec",
          "group": "1_actions"
        },
        {
          "command": "specCode.generateDesign",
          "when": "view == specCode.specs && viewItem == specWithRequirements",
          "group": "1_actions"
        },
        {
          "command": "specCode.generateTasks",
          "when": "view == specCode.specs && viewItem == specWithDesign",
          "group": "1_actions"
        },
        {
          "command": "specCode.executeTasks",
          "when": "view == specCode.specs && viewItem == specWithTasks",
          "group": "1_actions"
        },
        {
          "command": "specCode.editHook",
          "when": "view == specCode.hooks && viewItem == hook",
          "group": "inline"
        },
        {
          "command": "specCode.toggleHook",
          "when": "view == specCode.hooks && viewItem == hook",
          "group": "inline"
        },
        {
          "command": "specCode.deleteHook",
          "when": "view == specCode.hooks && viewItem == hook",
          "group": "inline"
        },
        {
          "command": "specCode.editSteering",
          "when": "view == specCode.steering && viewItem == steering",
          "group": "inline"
        },
        {
          "command": "specCode.endSession",
          "when": "view == specCode.sessions && viewItem == session",
          "group": "inline"
        },
        {
          "command": "specCode.removeMCPServer",
          "when": "view == specCode.mcp && viewItem == mcpServer",
          "group": "inline"
        },
        {
          "command": "specCode.testProvider",
          "when": "view == specCode.providerSwitcher && viewItem == providerInList",
          "group": "inline"
        },
        {
          "command": "specCode.editProvider",
          "when": "view == specCode.providerSwitcher && (viewItem == providerInList || viewItem == activeProviderInList)",
          "group": "1_actions"
        },
        {
          "command": "specCode.removeProvider",
          "when": "view == specCode.providerSwitcher && (viewItem == providerInList || viewItem == activeProviderInList)",
          "group": "1_actions"
        }
      ],
      "commandPalette": [
        {
          "command": "specCode.openChat",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.openSettings",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.openProviderSetup",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.explainCode",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.fixCode",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.askAboutCode",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.generateCommitMessage",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.reviewChanges",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.viewSessions",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.viewMemory",
          "group": "Spec-Code"
        },
        {
          "command": "specCode.addProvider",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.switchProvider",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.testProvider",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.discoverProviders",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.importProviderConfig",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.exportProviderConfig",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.activateProvider",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.setPhaseProvider",
          "group": "Spec-Code Providers"
        },
        {
          "command": "specCode.refreshProviderStatus",
          "group": "Spec-Code Providers"
        }
      ],
      "editor/context": [
        {
          "command": "specCode.askAboutSelection",
          "when": "editorHasSelection",
          "group": "specCode@1"
        },
        {
          "command": "specCode.explainCode",
          "when": "editorHasSelection",
          "group": "specCode@2"
        },
        {
          "command": "specCode.fixCode",
          "when": "editorHasSelection",
          "group": "specCode@3"
        },
        {
          "command": "specCode.generateTests",
          "when": "editorTextFocus",
          "group": "specCode@4"
        },
        {
          "command": "specCode.reviewCurrentFile",
          "when": "editorTextFocus",
          "group": "specCode@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "specCode.openChat",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      },
      {
        "command": "specCode.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "specCode.fixCode",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      },
      {
        "command": "specCode.generateCommitMessage",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "specCode.askAboutSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      },
      {
        "command": "specCode.generateTests",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      },
      {
        "command": "specCode.switchProvider",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p"
      },
      {
        "command": "specCode.addProvider",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p"
      },
      {
        "command": "specCode.testProvider",
        "key": "ctrl+shift+alt+t",
        "mac": "cmd+shift+alt+t"
      },
      {
        "command": "specCode.discoverProviders",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      }
    ],
    "configuration": {
      "title": "Spec-Code",
      "properties": {
        "specCode.models": {
          "type": "array",
          "default": [],
          "description": "Configured AI models",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "modelName": {
                "type": "string"
              },
              "apiKey": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "temperature": {
                "type": "number",
                "default": 0.7
              },
              "maxTokens": {
                "type": "number",
                "default": 4096
              },
              "supportsTools": {
                "type": "boolean",
                "default": true
              },
              "supportsVision": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "specCode.defaultRequirementsModel": {
          "type": "string",
          "default": "",
          "description": "Default model for Requirements phase"
        },
        "specCode.defaultDesignModel": {
          "type": "string",
          "default": "",
          "description": "Default model for Design phase"
        },
        "specCode.defaultExecutionModel": {
          "type": "string",
          "default": "",
          "description": "Default model for Execution phase"
        },
        "specCode.defaultHooksModel": {
          "type": "string",
          "default": "",
          "description": "Default model for Agent Hooks"
        },
        "specCode.enableCostTracking": {
          "type": "boolean",
          "default": true,
          "description": "Enable token and cost tracking"
        },
        "specCode.autoApproveTrustedCommands": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve commands matching trusted patterns"
        },
        "specCode.trustedCommandPatterns": {
          "type": "array",
          "default": [],
          "description": "Regex patterns for trusted commands",
          "items": {
            "type": "string"
          }
        },
        "specCode.enableHooks": {
          "type": "boolean",
          "default": true,
          "description": "Enable agent hooks"
        },
        "specCode.showVerificationPrompts": {
          "type": "boolean",
          "default": true,
          "description": "Show verification prompts at each phase"
        },
        "specCode.mcpServers": {
          "type": "object",
          "default": {},
          "description": "MCP server configurations"
        },
        "specCode.globalSteeringPath": {
          "type": "string",
          "default": "~/.specCode/steering",
          "description": "Path to global steering documents"
        },
        "specCode.activeProvider": {
          "type": "string",
          "default": "",
          "description": "Currently active provider ID"
        },
        "specCode.phaseProviders": {
          "type": "object",
          "default": {
            "requirements": "",
            "design": "",
            "execution": "",
            "hooks": ""
          },
          "description": "Provider IDs for each workflow phase"
        },
        "specCode.providerSettings": {
          "type": "object",
          "default": {
            "autoDiscovery": true,
            "healthCheckInterval": 300000,
            "circuitBreakerThreshold": 5,
            "defaultTimeout": 30000
          },
          "description": "Provider management settings"
        }
      }
    },
    "webview": {
      "specCode.chat": {
        "viewType": "specCode.chat",
        "preserveFocus": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.21.0",
    "@types/uuid": "^9.0.7",
    "axios": "^1.6.5",
    "glob": "^13.0.6",
    "openai": "^4.28.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  }
}
